# Copy to .env and fill in. Kafka BROKER config lives in kafka.env (committed), not here.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me            # database password
POSTGRES_DB=tideo

# --- RabbitMQ (broker credentials; the worker authenticates with these) ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me

# --- Kafka-UI (which cluster the UI connects to) ---
KAFKA_CLUSTERS_0_NAME=kafka
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=kafka:9092

# --- Service ports (the app builds connection URLs from these) ---
REDIS_PORT=6379
POSTGRES_PORT=5432
KAFKA_PORT=9092
RABBITMQ_PORT=5672

# --- Ops (REQUIRED) ---
ADMIN_TOKEN=change-me     
PROFILE=dev